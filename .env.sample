# ── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
BASE_URL=https://your-ngrok-url-or-domain.com

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tierce:tierce@localhost:5432/tierce_voice

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI (REQUIRED) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Native Audio model (Feature 1)
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Fine-tuning base model (Feature 3)
FINE_TUNE_BASE_MODEL=gpt-4o-mini-2024-07-18
AUTO_FINE_TUNE=true
FINE_TUNING_THRESHOLD=50

# ── Google Gemini (optional — for Gemini Live pipeline) ──────────────────────
GOOGLE_API_KEY=

# ── Telephony — Twilio ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── Telephony — Plivo (alternative to Twilio) ───────────────────────────────
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=

# ── STT Provider (classic pipeline only) ────────────────────────────────────
DEEPGRAM_API_KEY=

# ── TTS Provider (classic pipeline only) ────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Emotion Analysis ─────────────────────────────────────────────────────────
# "local" uses librosa (CPU-based, free), "hume" uses Hume AI API (better quality)
EMOTION_BACKEND=local
HUME_API_KEY=

# ── Storage (optional — for call recordings) ────────────────────────────────
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── ngrok (local dev only) ───────────────────────────────────────────────────
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-32-char-random-string
